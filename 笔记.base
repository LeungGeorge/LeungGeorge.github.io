filters:
  and:
    - file.ext == "md"
    - or:
        - file.folder == "source/_posts"
        - file.folder == "source/_discarded"
        - file.folder == "source/_drafts"
views:
  - type: table
    name: 表格
    order:
      - file.name
      - file.ctime
      - file.mtime
    sort:
      - property: date
        direction: DESC
